{
  "name": "claude-pilot",
  "version": "0.1.0",
  "description": "Claude-powered AI assistant application",
  "main": "dist/main/main.js",
  "author": "Ray <roydoy7@gmail.com>",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on tcp:127.0.0.1:5173 && electron dist/main/main.js\" -k",
    "dev:vscode": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "postinstall": "node scripts/setup-python-env.js && node scripts/setup-calibre.js && node scripts/setup-libreoffice.js",
    "setup:python": "node scripts/setup-python-env.js",
    "setup:calibre": "node scripts/setup-calibre.js",
    "setup:libreoffice": "node scripts/setup-libreoffice.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.176",
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mohtasham/md-to-docx": "^2.4.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/xml2js": "^0.4.14",
    "adm-zip": "^0.5.16",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "markitdown-ts": "^0.0.10",
    "officegen": "^0.6.5",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf-to-printer": "^5.6.1",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.19.1",
    "pptx-automizer": "^0.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.1",
    "xml2js": "^0.6.2",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/adm-zip": "^0.5.7",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.8",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.5.0",
    "playwright": "^1.57.0",
    "pptxgenjs": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.2.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.claude.pilot",
    "productName": "Claude Pilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/**/*",
      "node_modules/@napi-rs/**/*",
      "node_modules/@img/**/*",
      "node_modules/sharp/**/*"
    ],
    "extraResources": [
      {
        "from": "src/core/custom-skills",
        "to": "custom-skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/core/agent-defs",
        "to": "agent-defs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "packages/python-3.13.11-embed-amd64",
        "to": "python-3.13.11-embed-amd64",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "packages/libreofficePortable/LibreOfficePortable",
        "to": "LibreOfficePortable",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
